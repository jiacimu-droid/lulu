{
  "id": "com.orangechat.plugin.memory",
  "name": "记忆库",
  "description": "外置记忆库插件，支持每条消息自动存储、向量化召回、阶段总结和每日总结，跨对话窗口保持连续记忆",
  "version": "1.0.0",
  "author": "OrangeChat",
  "icon": "🧠",
  "entry": "main.js",
  "ui": {
    "title": "🧠 记忆库管理",
    "queries": {
      "all_memories": {
        "type": "dataStore_list",
        "params": { "prefix": "memory_" },
        "autoRefresh": true
      },
      "search_memories": {
        "type": "dataStore_search",
        "params": { "prefix": "memory_", "searchFields": ["content", "type", "tags"] },
        "autoRefresh": true
      }
    },
    "actions": {
      "save_memory": {
        "type": "dataStore_set",
        "params": { "key": "memory_${timestamp}", "value": "${form}" },
        "onSuccess": "refresh"
      },
      "delete_memory": {
        "type": "dataStore_delete",
        "params": { "key": "${key}" },
        "onSuccess": "refresh",
        "confirmDialog": {
          "title": "删除记忆",
          "message": "确定要删除这条记忆吗？此操作不可撤销。"
        }
      }
    },
    "components": [
      {
        "type": "stats",
        "props": {
          "items": [
            { "label": "总记忆", "queryName": "all_memories", "compute": "count" },
            { "label": "类型", "queryName": "all_memories", "compute": "unique", "field": "type" }
          ]
        }
      },
      {
        "type": "button_row",
        "props": {
          "buttons": [
            { "label": "+ 手动添加", "action": "add", "variant": "primary" },
            { "label": "🔄 刷新", "action": "refresh", "variant": "secondary" }
          ]
        }
      },
      {
        "type": "search_bar",
        "props": { "placeholder": "搜索记忆内容、标签..." }
      },
      {
        "type": "filter_bar",
        "props": { "queryName": "all_memories", "filterField": "type", "allLabel": "全部类型" }
      },
      {
        "type": "card_list",
        "props": {
          "queryName": "all_memories",
          "titleField": "content",
          "subtitleField": "tags",
          "tagField": "type",
          "deleteAction": "delete_memory",
          "deleteKeyField": "_key"
        }
      },
      {
        "type": "empty_state",
        "props": {
          "queryName": "all_memories",
          "message": "暂无记忆数据\n聊天时开启自动存储，记忆会自动保存到这里"
        }
      },
      {
        "type": "dialog_form",
        "props": {
          "triggerLabel": "+ 手动添加记忆",
          "triggerVariant": "primary",
          "title": "添加记忆",
          "fields": [
            { "name": "content", "label": "记忆内容", "type": "string", "required": true, "multiline": true, "placeholder": "输入要保存的记忆内容..." },
            { "name": "type", "label": "类型", "type": "select", "default": "manual", "placeholder": "选择记忆类型" },
            { "name": "tags", "label": "标签", "type": "string", "placeholder": "用逗号分隔，如：偏好,计划,事实" },
            { "name": "importance", "label": "重要性", "type": "integer", "default": "5", "placeholder": "1-10，数字越大越重要" }
          ],
          "submitAction": "save_memory",
          "submitLabel": "保存"
        }
      }
    ]
  },
  "tools": [
    {
      "name": "memory_recall",
      "description": "根据当前话题从记忆库中召回相关记忆，返回与当前对话相关的历史记忆片段",
      "parameters": [
        {
          "name": "query",
          "type": "string",
          "required": true,
          "description": "要搜索的关键词或话题"
        },
        {
          "name": "count",
          "type": "integer",
          "required": false,
          "description": "召回的记忆条数，默认使用配置中的值"
        }
      ]
    },
    {
      "name": "memory_save",
      "description": "主动保存一条记忆到记忆库",
      "parameters": [
        {
          "name": "content",
          "type": "string",
          "required": true,
          "description": "要保存的记忆内容"
        }
      ]
    },
    {
      "name": "memory_search",
      "description": "搜索记忆库中的记忆，用于查看或管理已有记忆",
      "parameters": [
        {
          "name": "keyword",
          "type": "string",
          "required": false,
          "description": "搜索关键词"
        },
        {
          "name": "type",
          "type": "string",
          "required": false,
          "description": "记忆类型过滤: message(消息), phase_summary(阶段总结), daily_summary(每日总结)"
        },
        {
          "name": "limit",
          "type": "integer",
          "required": false,
          "description": "返回条数限制，默认20"
        }
      ]
    },
    {
      "name": "memory_delete",
      "description": "删除记忆库中的一条记忆",
      "parameters": [
        {
          "name": "id",
          "type": "integer",
          "required": true,
          "description": "要删除的记忆ID"
        }
      ]
    }
  ],
  "config": [
    {
      "name": "embedding_api_key",
      "type": "password",
      "label": "向量服务 API Key",
      "description": "用于向量化消息的API密钥",
      "required": true,
      "placeholder": "sk-..."
    },
    {
      "name": "embedding_base_url",
      "type": "string",
      "label": "向量服务 Base URL",
      "description": "向量化服务的API地址",
      "required": true,
      "default": "https://api.openai.com/v1",
      "placeholder": "https://api.openai.com/v1"
    },
    {
      "name": "embedding_model",
      "type": "string",
      "label": "向量模型",
      "description": "用于向量化消息的模型名称，可点击拉取模型列表或手动填写",
      "required": true,
      "default": "text-embedding-3-small",
      "placeholder": "text-embedding-3-small"
    },
    {
      "name": "summary_api_key",
      "type": "password",
      "label": "总结服务 API Key",
      "description": "用于生成阶段总结和每日总结的API密钥（建议和聊天用的分开）",
      "required": true,
      "placeholder": "sk-..."
    },
    {
      "name": "summary_base_url",
      "type": "string",
      "label": "总结服务 Base URL",
      "description": "总结服务的API地址",
      "required": true,
      "default": "https://api.openai.com/v1",
      "placeholder": "https://api.openai.com/v1"
    },
    {
      "name": "summary_model",
      "type": "string",
      "label": "总结模型",
      "description": "用于生成总结的模型名称",
      "required": true,
      "default": "gpt-4o-mini",
      "placeholder": "gpt-4o-mini"
    },
    {
      "name": "recall_count",
      "type": "integer",
      "label": "召回条数",
      "description": "聊天时从记忆库召回多少条相关记忆",
      "required": false,
      "default": 5
    },
    {
      "name": "recent_message_count",
      "type": "integer",
      "label": "近期上文条数",
      "description": "发消息时带最近多少条原始消息作为上下文",
      "required": false,
      "default": 10
    },
    {
      "name": "phase_summary_count",
      "type": "integer",
      "label": "阶段总结条数",
      "description": "发消息时带最近多少条阶段总结",
      "required": false,
      "default": 3
    },
    {
      "name": "daily_summary_count",
      "type": "integer",
      "label": "每日总结天数",
      "description": "发消息时带最近多少天的每日总结",
      "required": false,
      "default": 3
    },
    {
      "name": "phase_summary_trigger",
      "type": "integer",
      "label": "阶段总结触发条数",
      "description": "每多少条消息触发一次阶段总结",
      "required": false,
      "default": 20
    },
    {
      "name": "max_retry_count",
      "type": "integer",
      "label": "失败重试次数",
      "description": "向量化或总结失败时的最大重试次数",
      "required": false,
      "default": 3
    },
    {
      "name": "auto_store_messages",
      "type": "boolean",
      "label": "自动存储消息",
      "description": "是否自动将每条消息存入记忆库",
      "required": false,
      "default": true
    },
    {
      "name": "auto_recall",
      "type": "boolean",
      "label": "自动召回记忆",
      "description": "是否在每条消息前自动从记忆库召回相关记忆",
      "required": false,
      "default": true
    },
    {
      "name": "auto_phase_summary",
      "type": "boolean",
      "label": "自动阶段总结",
      "description": "是否自动在达到条数阈值时生成阶段总结",
      "required": false,
      "default": true
    },
    {
      "name": "auto_daily_summary",
      "type": "boolean",
      "label": "自动每日总结",
      "description": "是否每天自动生成对话总结",
      "required": false,
      "default": true
    },
    {
      "name": "inject_as_prompt",
      "type": "boolean",
      "label": "注入为提示词",
      "description": "开启后，每次聊天会自动在系统提示词中告知AI可以使用记忆库工具，让AI主动调用记忆召回和保存",
      "required": false,
      "default": false
    }
  ],
  "promptTemplate": "你拥有记忆库能力。在对话中，你可以使用以下工具来管理记忆：\n1. memory_recall(query) - 根据话题召回相关历史记忆\n2. memory_save(content) - 主动保存重要信息到记忆库\n请在用户提到之前聊过的内容、个人偏好、重要事实时主动使用 memory_recall 查找相关记忆；在用户分享重要信息（如偏好、计划、事实）时主动使用 memory_save 保存。"
}
